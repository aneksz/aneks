{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "style": "/home/igor/.config/swaync/style.css",
    "positionX": "right",
    "positionY": "top",
    "layer": "top",
    "control-center-layer": "top",
    "layer-shell": true,
    "cssPriority": "user",
    "control-center-margin-top": 54,
    "control-center-margin-bottom": 2,
    "control-center-margin-right": 8,
    "control-center-margin-left": 0,
    "notification-2fa-action": true,
    "notification-inline-replies": true,
    "notification-icon-size": 20,
    "notification-body-image-height": 100,
    "notification-body-image-width": 300,
    "notification-window-width": 350,
    "notification-window-height": 128,
    "markup": true,
    "timeout": 3,
    "timeout-low": 3,
    "timeout-critical": 0,
    "fit-to-screen": false,
    "control-center-width": 380,
    "control-center-height": 800,
    "keyboard-shortcuts": true,
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": true,
    "script-fail-notify": true,
    "image-visibility": "never",
    "notification-visibility": {
    "mute-spotify": {
        "state": "muted",
        "urgency": "Normal",
        "app-name": "Spotify" 
    },
    "theme-switcher": {
    "state": "transient",
    "app-name": "theme-switcher"
    }
},


    "widgets": [
        "label",
        "buttons-grid",
        "dnd",
        "title",
        "notifications"
    ],
    
    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": ""
        },
        "label": {
            "max-lines": 1,
            "text": "Notification Centre"
        },
        "dnd": {
        "text": "Do Not Disturb"
        },
        "volume": {
            "label": ""
        },
        "notifications": {
            "timeout": 5,
            "hide-on-clear": true,
            "hide-on-action": true,
            "limit": 5,
            "history-size": 20,
            "max-lines": 20
        },
        "buttons-grid": {
            "actions": [
                {
                    "label": "󰍃",
                    "command": "wlogout",
                    "type": "toggle"
                },
                {
                    "label": "",
                    "command": "spotify"
                },
                
                {    "label": "",
                     "command": "steam"
                },
              
                {    "label": "",
                     "command": "kitty $HOME"
                }

        ]
    }
  }
}


