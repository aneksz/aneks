@import "colors.css";

/* =========================
   Gruvbox SwayNC Theme
   ========================= */

* {
    background: transparent;
    font-family: "Noto Sans";
    font-size: 12px;
    transition: 200ms;
}

/* Notifications */
.notification {
    background-color: @bg0;
    color: @fg0;
    border: 2px solid @border;
    border-radius: 12px;
    padding: 4px;
}

.notification-window,
.notifications-container,
.floating-notifications {
    background: transparent;
}

.control-center .notification .summary {
  margin-bottom: 4px;
  padding-bottom: 8px;
  line-height: 1.4;
}

.control-center .notification .body {
  margin-top: 14px;
  padding-top: 2px;
  line-height: 1.4;
}

.notification-content {
  margin-top: 4px;
}

.notification {
  padding: 6px 8px;
}

.notification .summary {
  padding: 2px 0;
  margin: 0;
  line-height: 1.4;
}

.notification .body {
  margin-top: 2px;
  padding-top: 2px;
  line-height: 1.4;
}

.summary {
  font-size: 14px;
  font-weight: 500;
  color: @blue;
}

.body {
  color: @fg0;
}

.time {
  color: @green;
  padding: 8px;
  margin-right: 2px;
}

/* Close button */
.close-button {
  background-color: @red;
  color: @bg0;
  border-radius: 6px;
}

.close-button:hover {
  background-color: @orange;
}

/* Actions */
.notification-default-action:hover,
.notification-action:hover {
    background-color: @bg0;
    color: @green;
}

/* Progress */
.notification.critical progress {
  background-color: @red;
}

.notification.low progress,
.notification.normal progress {
  background-color: @green;
}

/* Control Center */
.control-center {
    background: @bg0;
    color: @fg0;
    border: 1px solid @border;
    border-radius: 16px;
}

/* Groups */
.notification-group-collapse-button,
.notification-group-close-all-button {
  background-color: @bg0;
  color: @fg0;
  border-radius: 6px;
}

.notification-group-collapse-button:hover,
.notification-group-close-all-button:hover {
  background-color: @yellow;
  color: @bg0;
}

/* Widgets */
.widget-title {
color: @blue;
}
.widget-label {
  color: @green;
}

/* DND */
.widget-dnd {
  background-color: @bg0;
  border-radius: 8px;
  padding: 6px;
}

.widget-dnd label {
  color: @blue;
  font-weight: 500;
}

.widget-dnd > switch {
  background: @bg2;
}

.widget-dnd > switch:checked {
  background: @green;
}

.widget-dnd > switch slider {
  background: @bg0;
}

/* Buttons */
button {
    background-color: @bg2;
    color: @fg0;
    border-radius: 6px;
}

button:hover {
    background-color: @orange;
    color: @bg0;
}

/* Toggles */
.widget-buttons-grid > flowbox > flowboxchild > button.toggle:checked {
  background-color: @green;
  color: @bg0;
}

/* Sliders */
trough slider {
    background-color: @blue;
}

trough slider:hover {
    background-color: @yellow;
}

trough highlight {
  background-color: @green;
}

/* Misc */
.widget-volume {
    color: @aqua;
}

.widget-backlight {
  background-color: @bg2;
  color: @fg0;
}


/* Scroll */
scrollbar {
opacity: 0;
background: transparent;
}

scrollbar:active {
opacity: 1;
}

.notification-default-action .notification-content .summary {
  margin: 0;
  padding-top: 6px;
}

.notification-default-action .notification-content .body {
  margin-top: -10px; /* Adjust this number to kill the gap */
  margin-left: 0;
  margin-right: 0;
}

.notification-default-action .notification-content label {
  -gtk-icon-style: regular; /* Just a placeholder to ensure the block is read */
}


.notification-default-action .notification-content {
  padding-top: 6px;
  padding-bottom: 6px;
}

.control-center .notification-default-action .notification-content .body {
  margin-top: 0;
}

.notification.theme-switcher .notification-content {
  padding-top: 2px;
  padding-bottom: 2px;
  line-height: 1.3;
}

.notification.theme-switcher .body {
  margin-top: -10px;
  line-height: 1.4;
}



